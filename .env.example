# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored; never commit your real keys.

# Required — used by the Vite dev-server proxy to authenticate calls to api.anthropic.com.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — override the Anthropic API version header.
# ANTHROPIC_VERSION=2023-06-01

# ── Higgsfield (image generation) ───────────────────────────────────────────
# Required for portrait / asset image generation. Get from your Higgsfield
# dashboard. Auth header sent to platform.higgsfield.ai is:
#   Authorization: Key ${HIGGSFIELD_KEY_ID}:${HIGGSFIELD_KEY_SECRET}
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=
